<header class="hero-section" style="background-image: url('<%= wedding.couplePhoto || 'https://images.unsplash.com/photo-1519225421980-715cb0215aed?ixlib=rb-4.0.3&auto=format&fit=crop&w=2070&q=80' %>')">
    <div class="hero-overlay"></div>
    <div class="hero-content gs-reveal">
        <div class="kerala-ornament top"></div>
        <h3 class="hero-subtitle">Together with their families</h3>
        <h1 class="hero-title"><%= wedding.groomName %> & <%= wedding.brideName %></h1>
        <p class="hero-date">
            <% const d = new Date(wedding.weddingDate); %>
            <%= d.toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' }) %>
        </p>
        <p class="hero-venue"><%= wedding.venue?.name || 'Venue TBA' %></p>
        <div class="kerala-ornament bottom"></div>
    </div>
</header>

<main>
    <% if (wedding.invitationMessage) { %>
    <section class="invitation-section section-padding">
        <div class="container text-center gs-reveal">
            <h2 class="section-title">The Invitation</h2>
            <div class="ornament-divider"></div>
            <p class="invitation-text"><%= wedding.invitationMessage %></p>
        </div>
    </section>
    <% } %>

    <section class="couple-section section-padding bg-light">
        <div class="container">
            <div class="couple-grid">
                <div class="person-card gs-reveal gs-left">
                    <div class="person-photo-wrapper">
                        <img src="<%= wedding.groomPhoto || 'https://images.unsplash.com/photo-1506794778202-cad84cf45f1d?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>" alt="<%= wedding.groomName %>" class="person-photo">
                        <div class="photo-frame"></div>
                    </div>
                    <h3 class="person-name"><%= wedding.groomName %></h3>
                    <p class="person-parents">
                        Son of <%= wedding.groomFamily?.fatherName || 'Mr.' %> & <%= wedding.groomFamily?.motherName || 'Mrs.' %>
                    </p>
                </div>
                
                <div class="and-separator gs-reveal">&amp;</div>
                
                <div class="person-card gs-reveal gs-right">
                    <div class="person-photo-wrapper">
                        <img src="<%= wedding.bridePhoto || 'https://images.unsplash.com/photo-1534528741775-53994a69daeb?ixlib=rb-4.0.3&auto=format&fit=crop&w=800&q=80' %>" alt="<%= wedding.brideName %>" class="person-photo">
                        <div class="photo-frame"></div>
                    </div>
                    <h3 class="person-name"><%= wedding.brideName %></h3>
                    <p class="person-parents">
                        Daughter of <%= wedding.brideFamily?.fatherName || 'Mr.' %> & <%= wedding.brideFamily?.motherName || 'Mrs.' %>
                    </p>
                </div>
            </div>
            
            <% if (wedding.coupleStory) { %>
            <div class="story-container gs-reveal">
                <h3 class="story-title">Our Story</h3>
                <p class="story-text"><%= wedding.coupleStory %></p>
            </div>
            <% } %>
        </div>
    </section>

    <section class="events-section section-padding">
        <div class="container">
            <h2 class="section-title text-center gs-reveal">Wedding Details</h2>
            <div class="ornament-divider gs-reveal"></div>
            
            <div class="event-card gs-reveal">
                <h3 class="event-name">Muhurtham</h3>
                <div class="event-info">
                    <div class="info-item">
                        <span class="icon">📅</span>
                        <span><%= new Date(wedding.weddingDate).toLocaleDateString('en-US', { day: 'numeric', month: 'long', year: 'numeric' }) %></span>
                    </div>
                    <div class="info-item">
                        <span class="icon">⏰</span>
                        <span><%= wedding.weddingTime || '10:00 AM' %></span>
                    </div>
                    <div class="info-item">
                        <span class="icon">📍</span>
                        <span><%= wedding.venue?.name %>, <%= wedding.venue?.address %></span>
                    </div>
                </div>
                <% if (wedding.venue?.mapUrl) { %>
                <a href="<%= wedding.venue.mapUrl %>" target="_blank" class="btn btn-outline">View on Map</a>
                <% } %>
            </div>
        </div>
    </section>

    <% if (wedding.galleryPhotos && wedding.galleryPhotos.length > 0) { %>
    <section class="gallery-section section-padding bg-light">
        <div class="container">
            <h2 class="section-title text-center gs-reveal">Gallery</h2>
            <div class="ornament-divider gs-reveal"></div>
            <div class="gallery-grid">
                <% wedding.galleryPhotos.forEach((photo, index) => { %>
                    <div class="gallery-item gs-reveal" style="transition-delay: <%= index * 100 %>ms">
                        <img src="<%= photo.url %>" alt="<%= photo.caption || 'Wedding Photo' %>">
                    </div>
                <% }) %>
            </div>
        </div>
    </section>
    <% } %>

    <% if (wedding.isRsvpEnabled) { %>
    <section class="rsvp-trigger-section section-padding text-center">
        <div class="container gs-reveal">
            <h2 class="section-title">Are you attending?</h2>
            <p class="mb-4">Please let us know if you can make it to our special day.</p>
            <button class="btn btn-primary btn-large" onclick="openRsvpModal()">RSVP Now</button>
        </div>
    </section>
    <% } %>
</main>

<footer class="footer">
    <div class="container text-center">
        <div class="kerala-ornament footer-ornament"></div>
        <h2 class="footer-names"><%= wedding.groomName %> & <%= wedding.brideName %></h2>
        <p>Thank you for being part of our journey.</p>
        <p class="made-with">Created with Wedding Cards App</p>
    </div>
</footer>
