<!--
  Traditional Kerala — classical elegance
  Cream + gold + maroon accents, ornamental dividers, refined typography.
  Fonts: Cormorant Garamond (display) + Inter (body)
-->
<%- include('../partials/sections/icons') %>
<style>
  .traditional-kerala-template {
    --tk-bg: #FFF8F0;
    --tk-fg: #2C1810;
    --tk-muted: #6B5B47;
    --tk-line: #E5D4B7;
    --tk-primary: #D4A574;
    --tk-primary-dark: #B88A5C;
    --tk-maroon: #800020;
    --tk-maroon-dark: #5A0017;
    --tk-gold: #C9A95E;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--tk-fg); background: var(--tk-bg);
    line-height: 1.7; font-size: 17px;
  }
  .traditional-kerala-template .wsec-container { max-width: 1100px; margin: 0 auto; padding: 0 28px; }
  .traditional-kerala-template .wsec { padding: clamp(72px, 10vw, 120px) 0; position: relative; }
  .traditional-kerala-template .wsec-eyebrow-heading {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-style: italic;
    font-size: clamp(2.6rem, 5vw, 4rem); text-align: center;
    color: var(--tk-maroon); margin: 0 0 16px; letter-spacing: -0.01em; line-height: 1.1;
  }
  .traditional-kerala-template .wsec-eyebrow-heading::after {
    content: ''; display: block; width: 80px; height: 2px; background: var(--tk-gold);
    margin: 24px auto 48px; position: relative;
  }
  .traditional-kerala-template .wsec-eyebrow-heading::before {
    content: '✦'; position: absolute; left: 50%; top: 12px; transform: translateX(-50%);
    color: var(--tk-gold); font-size: 16px; background: var(--tk-bg); padding: 0 16px;
  }
  .traditional-kerala-template .wsec-eyebrow {
    font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: var(--tk-primary-dark);
    margin: 0 0 18px; font-weight: 500;
  }

  /* HERO — full-bleed photo with cream content card */
  .traditional-kerala-template .wsec-hero {
    padding: 0; min-height: 100vh; position: relative; overflow: hidden;
    display: grid; place-items: center;
  }
  .traditional-kerala-template .wsec-hero-bg {
    position: absolute; inset: 0; background-size: cover; background-position: center;
    transform: scale(1.05);
  }
  .traditional-kerala-template .wsec-hero-veil {
    position: absolute; inset: 0; background: linear-gradient(180deg, rgba(26,26,46,0.45), rgba(26,26,46,0.65));
  }
  .traditional-kerala-template .wsec-hero-inner {
    position: relative; z-index: 2; text-align: center; color: var(--tk-bg);
    padding: 64px 40px; max-width: 760px; background: rgba(26,26,46,0.32);
    backdrop-filter: blur(8px); border: 1px solid rgba(212,165,116,0.3); border-radius: 4px;
  }
  .traditional-kerala-template .wsec-names {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; color: var(--tk-bg);
    font-size: clamp(2.8rem, 7vw, 5.5rem); line-height: 1.05; margin: 0 0 24px; letter-spacing: -0.01em;
  }
  .traditional-kerala-template .wsec-names .wsec-name { display: block; }
  .traditional-kerala-template .wsec-names .wsec-amp {
    font-style: italic; color: var(--tk-primary); font-size: 0.7em; display: block; margin: 0.1em 0;
  }
  .traditional-kerala-template .wsec-date {
    font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.4rem;
    margin: 0 0 8px; color: var(--tk-primary);
  }
  .traditional-kerala-template .wsec-venue {
    font-size: 1rem; opacity: 0.95; margin: 0 0 32px; display: flex;
    align-items: center; justify-content: center; gap: 8px;
  }
  .traditional-kerala-template .wsec-venue .wsec-icon-inline { width: 16px; height: 16px; }
  .traditional-kerala-template .wsec-countdown {
    display: flex; gap: 14px; justify-content: center; margin: 24px 0 0; flex-wrap: wrap;
  }
  .traditional-kerala-template .wsec-cd-cell {
    background: rgba(255,248,240,0.12); backdrop-filter: blur(6px);
    border: 1px solid rgba(255,248,240,0.25); padding: 14px 18px; min-width: 78px;
  }
  .traditional-kerala-template .wsec-cd-num {
    display: block; font-family: 'Cormorant Garamond', serif; font-size: 2.4rem;
    font-weight: 500; line-height: 1; color: var(--tk-bg);
  }
  .traditional-kerala-template .wsec-cd-lbl {
    display: block; font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--tk-primary); margin-top: 6px;
  }
  .traditional-kerala-template .wsec-cd-celebrated { font-family: 'Cormorant Garamond', serif; font-style: italic; color: var(--tk-primary); }
  .traditional-kerala-template .wsec-scroll-cue {
    margin-top: 32px; display: inline-flex; align-items: center; gap: 10px;
    color: var(--tk-primary); font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    text-decoration: none;
  }
  .traditional-kerala-template .wsec-scroll-cue .wsec-icon-inline { width: 14px; height: 14px; }

  /* COUPLE — circular photos with parents */
  .traditional-kerala-template .wsec-couple { background: var(--tk-bg); }
  .traditional-kerala-template .wsec-couple-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; align-items: center;
    max-width: 900px; margin: 0 auto;
  }
  .traditional-kerala-template .wsec-person { text-align: center; }
  .traditional-kerala-template .wsec-person-photo-frame {
    width: clamp(180px, 22vw, 240px); height: clamp(180px, 22vw, 240px);
    border-radius: 50%; overflow: hidden; margin: 0 auto 24px; position: relative;
    background: var(--tk-line); padding: 6px; box-shadow: 0 12px 40px rgba(123,30,30,0.15);
  }
  .traditional-kerala-template .wsec-person-photo { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .traditional-kerala-template .wsec-person-name {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 2rem;
    color: var(--tk-maroon); margin: 0 0 8px;
  }
  .traditional-kerala-template .wsec-person-parents { color: var(--tk-muted); font-size: 0.95rem; margin: 0; font-style: italic; }
  .traditional-kerala-template .wsec-couple-amp {
    font-family: 'Cormorant Garamond', serif; font-size: 4rem; color: var(--tk-primary);
    font-style: italic;
  }
  .traditional-kerala-template .wsec-story {
    max-width: 800px; margin: 64px auto 0; text-align: center; padding: 48px 32px;
    background: var(--tk-bg); border: 1px solid var(--tk-line); position: relative;
  }
  .traditional-kerala-template .wsec-story::before, .traditional-kerala-template .wsec-story::after {
    content: '✦'; position: absolute; color: var(--tk-gold); font-size: 14px;
  }
  .traditional-kerala-template .wsec-story::before { top: 16px; left: 16px; }
  .traditional-kerala-template .wsec-story::after { bottom: 16px; right: 16px; }
  .traditional-kerala-template .wsec-icon-quote { width: 28px; height: 28px; color: var(--tk-gold); }
  .traditional-kerala-template .wsec-story-text {
    margin: 16px 0; font-family: 'Cormorant Garamond', serif; font-style: italic; font-size: 1.4rem;
    line-height: 1.6; color: var(--tk-fg); border: 0; padding: 0; background: transparent;
  }
  .traditional-kerala-template .wsec-story-attrib { color: var(--tk-muted); font-size: 0.9rem; letter-spacing: 1px; }

  /* OUR STORY */
  .traditional-kerala-template .wsec-our-story { background: var(--tk-bg); }
  .traditional-kerala-template .wsec-our-story .wsec-eyebrow { color: var(--tk-gold); }
  .traditional-kerala-template .wsec-our-story-body { max-width: 700px; margin: 0 auto; text-align: center; }
  .traditional-kerala-template .wsec-our-story-body p {
    font-family: 'Cormorant Garamond', serif; font-size: clamp(1.05rem, 2.2vw, 1.25rem);
    color: var(--tk-fg); line-height: 1.75; margin: 0 0 18px;
  }
  .traditional-kerala-template .wsec-our-story-body p:last-child { margin-bottom: 0; }
  .traditional-kerala-template .wsec-our-story-divider { margin: 32px auto 20px; }
  .traditional-kerala-template .wsec-our-story-divider::before,
  .traditional-kerala-template .wsec-our-story-divider::after { background: var(--tk-gold); opacity: 0.4; }
  .traditional-kerala-template .wsec-our-story-divider .wsec-divider-mark { color: var(--tk-gold); }
  .traditional-kerala-template .wsec-our-story-attrib {
    text-align: center; font-family: 'Cormorant Garamond', serif; font-style: italic;
    color: var(--tk-muted); font-size: 0.95rem;
  }

  /* FAMILY */
  .traditional-kerala-template .wsec-family { background: linear-gradient(180deg, var(--tk-bg), #fff); }
  .traditional-kerala-template .wsec-family-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; max-width: 920px; margin: 0 auto;
    align-items: start;
  }
  .traditional-kerala-template .wsec-family-col { text-align: center; }
  .traditional-kerala-template .wsec-family-name {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 1.5rem; margin: 0 0 24px;
    color: var(--tk-maroon);
  }
  .traditional-kerala-template .wsec-family-photo-frame {
    width: clamp(120px, 22vw, 200px); height: clamp(120px, 22vw, 200px);
    border-radius: 50%; margin: 0 auto 20px; overflow: hidden;
    border: 3px solid var(--tk-gold); padding: 4px; background: var(--tk-bg);
  }
  .traditional-kerala-template .wsec-family-photo-frame img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .traditional-kerala-template .wsec-family-avatar {
    width: clamp(120px, 22vw, 200px); height: clamp(120px, 22vw, 200px);
    border-radius: 50%; margin: 0 auto 20px;
    background: var(--tk-maroon); color: var(--tk-bg); display: grid; place-items: center;
    font-family: 'Cormorant Garamond', serif; font-size: clamp(2.6rem, 5vw, 4.5rem); font-weight: 500;
    border: 3px solid var(--tk-gold);
  }
  .traditional-kerala-template .wsec-family-list { list-style: none; padding: 0; margin: 0; }
  .traditional-kerala-template .wsec-family-list li {
    padding: 8px 0; border-top: 1px solid var(--tk-line);
    display: grid; grid-template-columns: auto 1fr; gap: 12px; text-align: left;
  }
  .traditional-kerala-template .wsec-family-list li:last-child { border-bottom: 1px solid var(--tk-line); }
  .traditional-kerala-template .wsec-family-role {
    font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--tk-muted);
  }
  .traditional-kerala-template .wsec-family-name-val { font-size: 1rem; color: var(--tk-fg); }
  .traditional-kerala-template .wsec-family-divider {
    width: 1px; align-self: stretch; background: linear-gradient(180deg, transparent, var(--tk-gold), transparent);
  }

  /* EVENTS */
  .traditional-kerala-template .wsec-events { background: #fff; }
  .traditional-kerala-template .wsec-timeline {
    list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto;
    position: relative;
  }
  .traditional-kerala-template .wsec-timeline::before {
    content: ''; position: absolute; left: 30px; top: 0; bottom: 0; width: 2px;
    background: linear-gradient(180deg, var(--tk-gold), var(--tk-primary));
  }
  .traditional-kerala-template .wsec-timeline-item {
    display: grid; grid-template-columns: 60px 1fr; gap: 24px; align-items: start;
    padding: 0 0 32px; position: relative;
  }
  .traditional-kerala-template .wsec-timeline-marker {
    width: 60px; display: grid; place-items: center; position: relative;
  }
  .traditional-kerala-template .wsec-timeline-marker::before {
    content: ''; position: absolute; width: 16px; height: 16px; border-radius: 50%;
    background: var(--tk-maroon); border: 3px solid var(--tk-bg); box-shadow: 0 0 0 2px var(--tk-gold);
  }
  .traditional-kerala-template .wsec-timeline-num { display: none; }
  .traditional-kerala-template .wsec-timeline-body { padding-top: 8px; }
  .traditional-kerala-template .wsec-timeline-title {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 1.6rem; margin: 0 0 6px;
    color: var(--tk-maroon);
  }
  .traditional-kerala-template .wsec-timeline-date {
    display: flex; align-items: center; gap: 8px; color: var(--tk-muted); font-size: 0.9rem; margin: 0 0 10px;
  }
  .traditional-kerala-template .wsec-timeline-date .wsec-icon-inline { width: 16px; height: 16px; }
  .traditional-kerala-template .wsec-timeline-desc { color: var(--tk-fg); margin: 0; }
  .traditional-kerala-template .wsec-event-card {
    max-width: 560px; margin: 0 auto; padding: 48px 40px; background: var(--tk-bg);
    border: 1px solid var(--tk-line); border-top: 4px solid var(--tk-gold); text-align: center;
    position: relative;
  }
  .traditional-kerala-template .wsec-event-card::before, .traditional-kerala-template .wsec-event-card::after {
    content: ''; position: absolute; width: 24px; height: 24px; border: 2px solid var(--tk-gold);
  }
  .traditional-kerala-template .wsec-event-card::before { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
  .traditional-kerala-template .wsec-event-card::after { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }
  .traditional-kerala-template .wsec-event-name {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 2.2rem; margin: 0 0 20px;
    color: var(--tk-maroon);
  }
  .traditional-kerala-template .wsec-event-info {
    list-style: none; padding: 0; margin: 0 0 28px; display: grid; gap: 10px;
  }
  .traditional-kerala-template .wsec-event-info li {
    display: flex; align-items: center; justify-content: center; gap: 10px; color: var(--tk-fg);
  }
  .traditional-kerala-template .wsec-icon { width: 18px; height: 18px; color: var(--tk-primary-dark); }

  /* GALLERY */
  .traditional-kerala-template .wsec-gallery { background: var(--tk-bg); }
  .traditional-kerala-template .wsec-gallery-grid {
    display: grid; grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); gap: 16px;
  }
  .traditional-kerala-template .wsec-gallery-item {
    padding: 0; border: 0; background: transparent; cursor: pointer; position: relative;
    overflow: hidden; aspect-ratio: 1; border-radius: 4px;
  }
  .traditional-kerala-template .wsec-gallery-item img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s;
  }
  .traditional-kerala-template .wsec-gallery-item:hover img { transform: scale(1.05); }
  .traditional-kerala-template .wsec-gallery-caption {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7)); color: white;
    font-size: 0.85rem;
  }

  /* TRAVEL */
  .traditional-kerala-template .wsec-travel { background: #fff; }
  .traditional-kerala-template .wsec-travel-layout {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; max-width: 1080px; margin: 0 auto;
  }
  .traditional-kerala-template .wsec-travel-subtitle {
    font-family: 'Cormorant Garamond', serif; font-weight: 500; font-size: 1.6rem; margin: 0 0 20px;
    color: var(--tk-maroon); display: flex; align-items: center; gap: 10px;
  }
  .traditional-kerala-template .wsec-travel-address {
    font-style: normal; color: var(--tk-fg); line-height: 1.8; display: grid; gap: 6px;
  }
  .traditional-kerala-template .wsec-travel-address strong { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; }
  .traditional-kerala-template .wsec-travel-notes { color: var(--tk-muted); font-size: 0.95rem; font-style: italic; }
  .traditional-kerala-template .wsec-travel-map iframe { width: 100%; aspect-ratio: 4/3; border: 0; background: var(--tk-line); }
  .traditional-kerala-template .wsec-hotels { margin-top: 64px; }
  .traditional-kerala-template .wsec-hotels-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .traditional-kerala-template .wsec-hotel-card {
    display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center;
    padding: 20px; background: var(--tk-bg); border: 1px solid var(--tk-line); border-left: 4px solid var(--tk-gold);
  }
  .traditional-kerala-template .wsec-hotel-name { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; margin: 0 0 4px; }
  .traditional-kerala-template .wsec-hotel-address, .traditional-kerala-template .wsec-hotel-distance { color: var(--tk-muted); font-size: 0.9rem; margin: 2px 0; display: flex; align-items: center; gap: 6px; }
  .traditional-kerala-template .wsec-icon-sm { width: 12px; height: 12px; }

  /* GIFT */
  .traditional-kerala-template .wsec-gift { background: var(--tk-bg); }
  .traditional-kerala-template .wsec-gift-intro { text-align: center; max-width: 540px; margin: 0 auto 48px; color: var(--tk-muted); font-style: italic; }
  .traditional-kerala-template .wsec-gift-list { list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto; display: grid; gap: 12px; }
  .traditional-kerala-template .wsec-gift-item {
    display: grid; grid-template-columns: 56px 1fr; gap: 20px; align-items: start;
    padding: 24px; background: white; border: 1px solid var(--tk-line); border-left: 4px solid var(--tk-gold);
  }
  .traditional-kerala-template .wsec-gift-icon { display: grid; place-items: center; }
  .traditional-kerala-template .wsec-gift-icon .wsec-icon { width: 24px; height: 24px; color: var(--tk-maroon); }
  .traditional-kerala-template .wsec-gift-label { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; margin: 0 0 6px; }
  .traditional-kerala-template .wsec-gift-value {
    display: inline-flex; align-items: center; gap: 8px; color: var(--tk-fg); text-decoration: none;
    font-family: 'Cormorant Garamond', serif; font-size: 1.05rem; background: transparent; border: 0; padding: 0;
    cursor: pointer; word-break: break-all;
  }
  .traditional-kerala-template .wsec-gift-value:hover { color: var(--tk-maroon); }
  .traditional-kerala-template .wsec-gift-value .wsec-icon { width: 16px; height: 16px; color: var(--tk-muted); }
  .traditional-kerala-template .wsec-gift-note { color: var(--tk-muted); font-size: 0.9rem; margin: 8px 0 0; font-style: italic; }

  /* WISHES */
  .traditional-kerala-template .wsec-wishes {
    background: linear-gradient(135deg, var(--tk-maroon), var(--tk-maroon-dark));
    color: var(--tk-bg); position: relative;
  }
  .traditional-kerala-template .wsec-wishes-sub { text-align: center; color: rgba(255,248,240,0.85); max-width: 540px; margin: 0 auto 32px; }
  .traditional-kerala-template .wsec-wishes-form { max-width: 560px; margin: 0 auto 56px; display: grid; gap: 14px; }
  .traditional-kerala-template .wsec-wishes-field { display: block; }
  .traditional-kerala-template .wsec-wishes-label {
    display: block; font-family: 'Cormorant Garamond', serif; font-style: italic;
    font-size: 13px; color: var(--tk-gold); margin-bottom: 8px;
  }
  .traditional-kerala-template .wsec-wishes-form input,
  .traditional-kerala-template .wsec-wishes-form textarea {
    width: 100%; padding: 14px 16px; border: 1px solid var(--tk-gold);
    border-radius: 4px; background: rgba(255,248,240,0.1); color: var(--tk-bg);
    font-family: 'Cormorant Garamond', serif; font-size: 16px;
  }
  .traditional-kerala-template .wsec-wishes-form input::placeholder,
  .traditional-kerala-template .wsec-wishes-form textarea::placeholder { color: rgba(255,248,240,0.55); font-style: italic; }
  .traditional-kerala-template .wsec-wishes-form input:focus,
  .traditional-kerala-template .wsec-wishes-form textarea:focus {
    outline: none; background: rgba(255,248,240,0.16); box-shadow: 0 0 0 2px var(--tk-gold);
  }
  .traditional-kerala-template .wsec-wishes-form textarea { resize: vertical; min-height: 90px; }
  .traditional-kerala-template .wsec-wishes-counter { text-align: right; font-size: 11px; color: rgba(255,248,240,0.65); margin: -8px 4px 0; }
  .traditional-kerala-template .wsec-wishes-submit {
    background: var(--tk-gold); color: var(--tk-maroon-dark); border: 1px solid var(--tk-gold);
    width: 100%; justify-content: center; font-family: 'Cormorant Garamond', serif; letter-spacing: 0.05em;
    border-radius: 4px;
  }
  .traditional-kerala-template .wsec-wishes-submit:hover { background: transparent; color: var(--tk-gold); }
  .traditional-kerala-template .wsec-wishes-status { text-align: center; font-size: 13px; margin: 8px 0 0; min-height: 1em; }
  .traditional-kerala-template .wsec-wishes-status.is-success { color: var(--tk-gold); font-weight: 600; }
  .traditional-kerala-template .wsec-wishes-status.is-error { color: #FFE5E5; }
  .traditional-kerala-template .wsec-wishes-list-wrap { max-width: 720px; margin: 0 auto; }
  .traditional-kerala-template .wsec-wishes-list-heading {
    font-family: 'Cormorant Garamond', serif; font-size: clamp(1.4rem, 3vw, 1.8rem);
    color: var(--tk-gold); text-align: center; margin: 0 0 24px;
  }
  .traditional-kerala-template .wsec-wishes-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 14px; }
  .traditional-kerala-template .wsec-wishes-item {
    background: rgba(255,248,240,0.08); border: 1px solid var(--tk-gold);
    border-radius: 4px; padding: 18px 20px; color: var(--tk-bg);
  }
  .traditional-kerala-template .wsec-wishes-msg {
    font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-style: italic;
    line-height: 1.5; margin-bottom: 8px;
  }
  .traditional-kerala-template .wsec-wishes-meta { display: flex; gap: 10px; align-items: center; font-size: 12px; color: var(--tk-gold); }
  .traditional-kerala-template .wsec-wishes-name { font-style: italic; }
  .traditional-kerala-template .wsec-wishes-empty { text-align: center; color: rgba(255,248,240,0.7); padding: 16px 0; }

  /* BUTTONS */
  .traditional-kerala-template .wsec-btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
    font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    border-radius: 4px; border: 1px solid; cursor: pointer; transition: all 0.3s; text-decoration: none;
    font-weight: 500;
  }
