<!--
  Modern Elegant — minimal editorial template
  Style: Black/white/cream, oversized display type, asymmetric layouts, large empty space, photo-driven.
  Fonts: Fraunces (display) + Inter (body)
-->
<%- include('../partials/sections/icons') %>
<style>
  .modern-elegant-template {
    --me-bg: #FAF7F2;
    --me-fg: #1A1A1A;
    --me-muted: #6E6A63;
    --me-line: #E5E0D8;
    --me-accent: #1A1A1A;
    --me-soft: #FFFFFF;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--me-fg);
    background: var(--me-bg);
    line-height: 1.6;
    font-size: 17px;
  }
  .modern-elegant-template .wsec-container { max-width: 1180px; margin: 0 auto; padding: 0 28px; }
  .modern-elegant-template .wsec { padding: clamp(72px, 10vw, 140px) 0; position: relative; }
  .modern-elegant-template .wsec-eyebrow-heading {
    font-family: 'Fraunces', serif; font-weight: 400; font-size: clamp(2.4rem, 5vw, 4.5rem);
    text-align: center; letter-spacing: -0.02em; margin: 0 0 64px; line-height: 1.05;
  }
  .modern-elegant-template .wsec-eyebrow {
    font-family: 'Inter', sans-serif; font-size: 12px; letter-spacing: 4px;
    text-transform: uppercase; color: var(--me-muted); margin: 0 0 18px;
  }

  /* HERO — asymmetric two-column, 60/40 split, no veil */
  .modern-elegant-template .wsec-hero {
    padding: 0; min-height: 100vh; display: grid; grid-template-columns: 1.1fr 1fr;
    background: var(--me-bg);
  }
  .modern-elegant-template .wsec-hero-bg { display: none; }
  .modern-elegant-template .wsec-hero-veil { display: none; }
  .modern-elegant-template .wsec-hero-inner {
    display: flex; flex-direction: column; justify-content: center;
    padding: 80px 64px 80px 80px; max-width: 720px;
  }
  .modern-elegant-template .wsec-names {
    font-family: 'Fraunces', serif; font-weight: 300; font-style: normal;
    font-size: clamp(3.5rem, 8vw, 7.5rem); line-height: 0.95; letter-spacing: -0.04em;
    margin: 0 0 24px; color: var(--me-fg);
  }
  .modern-elegant-template .wsec-names .wsec-name { display: block; }
  .modern-elegant-template .wsec-names .wsec-amp {
    display: block; font-size: 0.5em; color: var(--me-muted); font-style: italic; margin: 0.1em 0 0.2em;
  }
  .modern-elegant-template .wsec-date {
    font-family: 'Fraunces', serif; font-style: italic; font-size: 1.4rem;
    color: var(--me-muted); margin: 0 0 6px;
  }
  .modern-elegant-template .wsec-venue {
    font-size: 1rem; color: var(--me-muted); margin: 0 0 32px;
    display: flex; align-items: center; gap: 8px;
  }
  .modern-elegant-template .wsec-venue .wsec-icon-inline { width: 16px; height: 16px; }
  .modern-elegant-template .wsec-countdown {
    display: flex; gap: 12px; margin: 16px 0 32px; flex-wrap: wrap;
  }
  .modern-elegant-template .wsec-cd-cell {
    background: transparent; border: 1px solid var(--me-line);
    padding: 14px 18px; min-width: 80px; text-align: left;
  }
  .modern-elegant-template .wsec-cd-num {
    display: block; font-family: 'Fraunces', serif; font-size: 2.2rem; font-weight: 300;
    line-height: 1; color: var(--me-fg);
  }
  .modern-elegant-template .wsec-cd-lbl {
    display: block; font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--me-muted); margin-top: 6px;
  }
  .modern-elegant-template .wsec-cd-celebrated {
    font-family: 'Fraunces', serif; font-style: italic; font-size: 1.4rem; color: var(--me-fg);
  }
  .modern-elegant-template .wsec-scroll-cue {
    margin-top: 24px; display: inline-flex; align-items: center; gap: 10px;
    color: var(--me-muted); font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    text-decoration: none; align-self: flex-start;
  }
  .modern-elegant-template .wsec-scroll-cue:hover { color: var(--me-fg); }
  .modern-elegant-template .wsec-scroll-cue .wsec-icon-inline { width: 14px; height: 14px; }
  .modern-elegant-template .wsec-hero > div:last-child {
    background-size: cover; background-position: center;
  }
  .modern-elegant-template .wsec-hero {
    background-image: none;
  }
  .modern-elegant-template .wsec-hero::after {
    content: ''; display: block; background-size: cover; background-position: center;
    background-image: var(--me-hero-photo);
  }
  .modern-elegant-template { --me-hero-photo: url('<%= wedding.couplePhoto || "https://images.unsplash.com/photo-1519741497674-611481863552?ixlib=rb-4.0.3&auto=format&fit=crop&w=1400&q=80" %>'); }

  /* COUPLE — center-aligned with photo strip */
  .modern-elegant-template .wsec-couple { background: var(--me-bg); }
  .modern-elegant-template .wsec-couple-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px;
    align-items: center; max-width: 980px; margin: 0 auto;
  }
  .modern-elegant-template .wsec-person { text-align: center; }
  .modern-elegant-template .wsec-person-photo-frame {
    width: clamp(160px, 20vw, 240px); height: clamp(160px, 20vw, 240px);
    border-radius: 0; overflow: hidden; margin: 0 auto 20px; background: var(--me-line);
  }
  .modern-elegant-template .wsec-person-photo { width: 100%; height: 100%; object-fit: cover; }
  .modern-elegant-template .wsec-person-name {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: 1.8rem;
    margin: 0 0 6px; letter-spacing: -0.01em;
  }
  .modern-elegant-template .wsec-person-parents { color: var(--me-muted); font-size: 0.9rem; margin: 0; }
  .modern-elegant-template .wsec-couple-amp {
    font-family: 'Fraunces', serif; font-size: 3rem; color: var(--me-muted); font-style: italic;
  }
  .modern-elegant-template .wsec-story {
    max-width: 720px; margin: 80px auto 0; text-align: center;
    padding: 48px 0; border-top: 1px solid var(--me-line); border-bottom: 1px solid var(--me-line);
  }
  .modern-elegant-template .wsec-icon-quote { width: 28px; height: 28px; color: var(--me-muted); }
  .modern-elegant-template .wsec-story-text {
    margin: 16px 0; font-family: 'Fraunces', serif; font-style: italic; font-size: 1.5rem;
    line-height: 1.5; color: var(--me-fg); border: 0; padding: 0; background: transparent;
  }
  .modern-elegant-template .wsec-story-attrib { color: var(--me-muted); font-size: 0.9rem; letter-spacing: 2px; }

  /* OUR STORY */
  .modern-elegant-template .wsec-our-story { background: var(--me-soft); }
  .modern-elegant-template .wsec-our-story .wsec-eyebrow { color: var(--me-muted); }
  .modern-elegant-template .wsec-our-story-body { max-width: 660px; margin: 0 auto; text-align: left; }
  .modern-elegant-template .wsec-our-story-body p {
    font-family: 'Fraunces', serif; font-weight: 300;
    font-size: clamp(1.05rem, 2.4vw, 1.3rem);
    color: var(--me-fg); line-height: 1.75; margin: 0 0 18px;
  }
  .modern-elegant-template .wsec-our-story-body p:last-child { margin-bottom: 0; }
  .modern-elegant-template .wsec-our-story-divider { margin: 32px auto 20px; }
  .modern-elegant-template .wsec-our-story-divider::before,
  .modern-elegant-template .wsec-our-story-divider::after { background: var(--me-line); }
  .modern-elegant-template .wsec-our-story-divider .wsec-divider-mark { color: var(--me-fg); font-style: italic; }
  .modern-elegant-template .wsec-our-story-attrib {
    text-align: center; font-family: 'Inter', sans-serif; font-size: 11px;
    color: var(--me-muted); letter-spacing: 0.25em; text-transform: uppercase;
  }

  /* FAMILY */
  .modern-elegant-template .wsec-family { background: var(--me-soft); }
  .modern-elegant-template .wsec-family-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px;
    max-width: 920px; margin: 0 auto; align-items: start;
  }
  .modern-elegant-template .wsec-family-col { text-align: center; }
  .modern-elegant-template .wsec-family-name {
    font-family: 'Fraunces', serif; font-weight: 400; font-size: 1.4rem; margin: 0 0 20px;
  }
  .modern-elegant-template .wsec-family-photo-frame {
    width: clamp(120px, 22vw, 180px); height: clamp(120px, 22vw, 180px);
    margin: 0 auto 20px; overflow: hidden; border-radius: 0;
  }
  .modern-elegant-template .wsec-family-photo-frame img { width: 100%; height: 100%; object-fit: cover; }
  .modern-elegant-template .wsec-family-avatar {
    width: clamp(120px, 22vw, 180px); height: clamp(120px, 22vw, 180px);
    margin: 0 auto 20px; border-radius: 50%;
    background: var(--me-fg); color: var(--me-bg); display: grid; place-items: center;
    font-family: 'Fraunces', serif; font-size: clamp(2.4rem, 5vw, 4rem); font-weight: 300;
  }
  .modern-elegant-template .wsec-family-list { list-style: none; padding: 0; margin: 0; }
  .modern-elegant-template .wsec-family-list li { padding: 6px 0; }
  .modern-elegant-template .wsec-family-role {
    display: inline-block; font-size: 10px; letter-spacing: 2px; text-transform: uppercase;
    color: var(--me-muted); margin-right: 8px; min-width: 60px;
  }
  .modern-elegant-template .wsec-family-name-val { font-size: 1rem; color: var(--me-fg); }
  .modern-elegant-template .wsec-family-divider {
    width: 1px; align-self: stretch; background: var(--me-line);
  }

  /* EVENTS */
  .modern-elegant-template .wsec-events { background: var(--me-bg); }
  .modern-elegant-template .wsec-timeline {
    list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto;
    display: grid; gap: 32px;
  }
  .modern-elegant-template .wsec-timeline-item {
    display: grid; grid-template-columns: 80px 1fr; gap: 24px; align-items: start;
    padding: 32px 0; border-top: 1px solid var(--me-line);
  }
  .modern-elegant-template .wsec-timeline-marker { font-family: 'Fraunces', serif; }
  .modern-elegant-template .wsec-timeline-num { font-size: 1.2rem; color: var(--me-muted); font-weight: 300; }
  .modern-elegant-template .wsec-timeline-title {
    font-family: 'Fraunces', serif; font-weight: 400; font-size: 1.8rem; margin: 0 0 8px;
  }
  .modern-elegant-template .wsec-timeline-date {
    display: flex; align-items: center; gap: 8px; color: var(--me-muted); font-size: 0.95rem; margin: 0 0 12px;
  }
  .modern-elegant-template .wsec-timeline-date .wsec-icon-inline { width: 16px; height: 16px; }
  .modern-elegant-template .wsec-timeline-desc { color: var(--me-fg); margin: 0; }
  .modern-elegant-template .wsec-event-card {
    max-width: 560px; margin: 0 auto; padding: 56px 48px; background: var(--me-soft);
    border: 1px solid var(--me-line); text-align: center;
  }
  .modern-elegant-template .wsec-event-name {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: 2.5rem; margin: 0 0 24px;
  }
  .modern-elegant-template .wsec-event-info {
    list-style: none; padding: 0; margin: 0 0 32px; display: grid; gap: 8px;
  }
  .modern-elegant-template .wsec-event-info li {
    display: flex; align-items: center; justify-content: center; gap: 10px; color: var(--me-fg);
  }
  .modern-elegant-template .wsec-icon { width: 18px; height: 18px; }

  /* GALLERY */
  .modern-elegant-template .wsec-gallery { background: var(--me-soft); }
  .modern-elegant-template .wsec-gallery-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px;
  }
  .modern-elegant-template .wsec-gallery-item {
    padding: 0; border: 0; background: transparent; cursor: pointer;
    position: relative; overflow: hidden; aspect-ratio: 1; transition: opacity 0.3s;
  }
  .modern-elegant-template .wsec-gallery-item img {
    width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s;
  }
  .modern-elegant-template .wsec-gallery-item:hover img { transform: scale(1.05); }
  .modern-elegant-template .wsec-gallery-caption {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 16px;
    background: linear-gradient(transparent, rgba(0,0,0,0.7)); color: white;
    font-size: 0.85rem; text-align: left;
  }

  /* TRAVEL */
  .modern-elegant-template .wsec-travel { background: var(--me-bg); }
  .modern-elegant-template .wsec-travel-layout {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; max-width: 1080px; margin: 0 auto;
  }
  .modern-elegant-template .wsec-travel-subtitle {
    font-family: 'Fraunces', serif; font-size: 1.4rem; margin: 0 0 20px;
    display: flex; align-items: center; gap: 10px;
  }
  .modern-elegant-template .wsec-travel-address {
    font-style: normal; color: var(--me-fg); line-height: 1.8; display: grid; gap: 8px;
  }
  .modern-elegant-template .wsec-travel-address strong { font-family: 'Fraunces', serif; font-size: 1.2rem; }
  .modern-elegant-template .wsec-travel-notes { color: var(--me-muted); font-size: 0.95rem; }
  .modern-elegant-template .wsec-travel-map iframe {
    width: 100%; aspect-ratio: 4/3; border: 0; background: var(--me-line);
  }
  .modern-elegant-template .wsec-hotels { margin-top: 64px; }
  .modern-elegant-template .wsec-hotels-list {
    list-style: none; padding: 0; margin: 0; display: grid; gap: 16px;
  }
  .modern-elegant-template .wsec-hotel-card {
    display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center;
    padding: 20px 0; border-top: 1px solid var(--me-line);
  }
  .modern-elegant-template .wsec-hotel-name { font-family: 'Fraunces', serif; font-size: 1.2rem; margin: 0 0 4px; }
  .modern-elegant-template .wsec-hotel-address, .wsec-hotel-distance { color: var(--me-muted); font-size: 0.9rem; margin: 2px 0; display: flex; align-items: center; gap: 6px; }
  .modern-elegant-template .wsec-icon-sm { width: 12px; height: 12px; }

  /* GIFT */
  .modern-elegant-template .wsec-gift { background: var(--me-soft); }
  .modern-elegant-template .wsec-gift-intro {
    text-align: center; max-width: 540px; margin: 0 auto 48px; color: var(--me-muted);
  }
  .modern-elegant-template .wsec-gift-list {
    list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto;
    display: grid; gap: 0;
  }
  .modern-elegant-template .wsec-gift-item {
    display: grid; grid-template-columns: 56px 1fr; gap: 20px; align-items: start;
    padding: 28px 0; border-top: 1px solid var(--me-line);
  }
  .modern-elegant-template .wsec-gift-item:last-child { border-bottom: 1px solid var(--me-line); }
  .modern-elegant-template .wsec-gift-icon { display: grid; place-items: center; }
  .modern-elegant-template .wsec-gift-icon .wsec-icon { width: 24px; height: 24px; color: var(--me-fg); }
  .modern-elegant-template .wsec-gift-label { font-family: 'Fraunces', serif; font-size: 1.3rem; margin: 0 0 8px; }
  .modern-elegant-template .wsec-gift-value {
    display: inline-flex; align-items: center; gap: 8px; color: var(--me-fg); text-decoration: none;
    font-family: 'Fraunces', serif; font-size: 1.05rem; background: transparent; border: 0; padding: 0;
    cursor: pointer; word-break: break-all;
  }
  .modern-elegant-template .wsec-gift-value:hover { text-decoration: underline; }
  .modern-elegant-template .wsec-gift-value .wsec-icon { width: 16px; height: 16px; color: var(--me-muted); }
  .modern-elegant-template .wsec-gift-note { color: var(--me-muted); font-size: 0.9rem; margin: 8px 0 0; }

  /* RSVP */
  /* WISHES */
  .modern-elegant-template .wsec-wishes { background: var(--me-fg); color: var(--me-bg); }
  .modern-elegant-template .wsec-wishes-sub { text-align: center; color: rgba(250,247,242,0.7); max-width: 540px; margin: 0 auto 32px; }
  .modern-elegant-template .wsec-wishes-form { max-width: 560px; margin: 0 auto 56px; display: grid; gap: 16px; }
  .modern-elegant-template .wsec-wishes-field { display: block; }
  .modern-elegant-template .wsec-wishes-label {
    display: block; font-family: 'Inter', sans-serif; font-size: 10px; letter-spacing: 3px;
    text-transform: uppercase; color: rgba(250,247,242,0.65); margin-bottom: 8px;
  }
  .modern-elegant-template .wsec-wishes-form input,
  .modern-elegant-template .wsec-wishes-form textarea {
    width: 100%; padding: 14px 0; border: 0; border-bottom: 1px solid rgba(250,247,242,0.4);
    background: transparent; color: var(--me-bg); font-family: 'Fraunces', serif; font-size: 16px;
    border-radius: 0;
  }
  .modern-elegant-template .wsec-wishes-form input::placeholder,
  .modern-elegant-template .wsec-wishes-form textarea::placeholder { color: rgba(250,247,242,0.4); font-style: italic; }
  .modern-elegant-template .wsec-wishes-form input:focus,
  .modern-elegant-template .wsec-wishes-form textarea:focus {
    outline: none; border-bottom-color: var(--me-bg);
  }
  .modern-elegant-template .wsec-wishes-form textarea { resize: vertical; min-height: 90px; }
  .modern-elegant-template .wsec-wishes-counter { text-align: right; font-size: 11px; color: rgba(250,247,242,0.55); margin: -8px 4px 0; }
  .modern-elegant-template .wsec-wishes-submit {
    background: var(--me-bg); color: var(--me-fg); border: 1px solid var(--me-bg);
    border-radius: 0; width: 100%; justify-content: center;
  }
  .modern-elegant-template .wsec-wishes-submit:hover { background: transparent; color: var(--me-bg); }
  .modern-elegant-template .wsec-wishes-status { text-align: center; font-size: 13px; margin: 8px 0 0; min-height: 1em; }
  .modern-elegant-template .wsec-wishes-status.is-success { color: var(--me-bg); font-weight: 600; }
  .modern-elegant-template .wsec-wishes-status.is-error { color: #FFC4C4; }
  .modern-elegant-template .wsec-wishes-list-wrap { max-width: 720px; margin: 0 auto; }
  .modern-elegant-template .wsec-wishes-list-heading {
    font-family: 'Fraunces', serif; font-weight: 300;
    font-size: clamp(1.4rem, 3vw, 1.8rem);
    color: var(--me-bg); text-align: center; margin: 0 0 24px; letter-spacing: 0.02em;
  }
  .modern-elegant-template .wsec-wishes-list { list-style: none; padding: 0; margin: 0; display: grid; }
  .modern-elegant-template .wsec-wishes-item {
    padding: 24px 0; border-top: 1px solid rgba(250,247,242,0.2); color: var(--me-bg);
  }
  .modern-elegant-template .wsec-wishes-item:last-child { border-bottom: 1px solid rgba(250,247,242,0.2); }
  .modern-elegant-template .wsec-wishes-msg {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: 1.15rem;
    line-height: 1.55; margin-bottom: 8px;
  }
  .modern-elegant-template .wsec-wishes-meta {
    display: flex; gap: 12px; align-items: center; font-size: 11px; letter-spacing: 0.15em;
    text-transform: uppercase; color: rgba(250,247,242,0.65);
  }
  .modern-elegant-template .wsec-wishes-name { font-weight: 500; }
  .modern-elegant-template .wsec-wishes-empty { text-align: center; color: rgba(250,247,242,0.6); padding: 16px 0; }

  /* BUTTONS */
  .modern-elegant-template .wsec-btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 16px 32px;
    font-family: 'Inter', sans-serif; font-size: 12px; letter-spacing: 3px; text-transform: uppercase;
    border-radius: 0; border: 1px solid; cursor: pointer; transition: all 0.3s; text-decoration: none;
  }
  .modern-elegant-template .wsec-btn .wsec-icon { width: 16px; height: 16px; }
  .modern-elegant-template .wsec-btn-primary {
    background: var(--me-bg); color: var(--me-fg); border-color: var(--me-bg);
  }
  .modern-elegant-template .wsec-btn-primary:hover { background: transparent; color: var(--me-bg); }
  .modern-elegant-template .wsec-btn-outline {
    background: transparent; color: var(--me-fg); border-color: var(--me-fg);
  }
  .modern-elegant-template .wsec-btn-outline:hover { background: var(--me-fg); color: var(--me-bg); }
  .modern-elegant-template .wsec-btn-ghost {
    background: transparent; color: var(--me-fg); border-color: var(--me-line);
  }
  .modern-elegant-template .wsec-btn-ghost:hover { border-color: var(--me-fg); }

  /* FOOTER */
  .modern-elegant-template .wsec-footer {
    background: var(--me-bg); padding: 80px 0; text-align: center; border-top: 1px solid var(--me-line);
  }
  .modern-elegant-template .wsec-footer-eyebrow {
    font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--me-muted); margin: 0 0 24px;
  }
  .modern-elegant-template .wsec-footer-names {
    font-family: 'Fraunces', serif; font-weight: 300; font-size: clamp(2.5rem, 6vw, 4.5rem);
    margin: 0 0 16px; line-height: 1; letter-spacing: -0.02em;
  }
  .modern-elegant-template .wsec-footer-amp { color: var(--me-muted); font-style: italic; display: inline-block; margin: 0 0.2em; }
  .modern-elegant-template .wsec-footer-date { color: var(--me-muted); font-size: 0.9rem; margin: 0 0 32px; }
  .modern-elegant-template .wsec-footer-made { color: var(--me-muted); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

  /* FLOATING UI */
