<!--
  Royal Maroon — regal heritage
  Deep maroon + gold, Art Deco corner ornaments, double-border invitation card.
  Fonts: Cinzel (display) + Cormorant Garamond (body italic accents)
-->
<%- include('../partials/sections/icons') %>
<style>
  .royal-maroon-template {
    --rm-bg: #FFF8F0;
    --rm-fg: #2A0E0E;
    --rm-muted: #6B5050;
    --rm-line: #C9A95E;
    --rm-primary: #800020;
    --rm-primary-dark: #4A0014;
    --rm-gold: #C9A95E;
    --rm-cream: #FAF1E0;
    font-family: 'Cormorant Garamond', serif;
    color: var(--rm-fg); background: var(--rm-bg);
    line-height: 1.7; font-size: 18px;
  }
  .royal-maroon-template .wsec-container { max-width: 1120px; margin: 0 auto; padding: 0 28px; }
  .royal-maroon-template .wsec { padding: clamp(72px, 10vw, 130px) 0; position: relative; }
  .royal-maroon-template .wsec-eyebrow-heading {
    font-family: 'Cinzel', serif; font-weight: 500;
    font-size: clamp(1.6rem, 3.5vw, 2.6rem); text-align: center; color: var(--rm-primary);
    margin: 0 0 16px; letter-spacing: 0.15em; text-transform: uppercase; line-height: 1.2;
  }
  .royal-maroon-template .wsec-eyebrow-heading::after {
    content: ''; display: block; width: 100px; height: 1px; background: var(--rm-gold);
    margin: 24px auto; position: relative;
  }
  .royal-maroon-template .wsec-eyebrow-heading::before {
    content: '◆'; position: absolute; left: 50%; transform: translateX(-50%);
    color: var(--rm-gold); font-size: 14px; background: var(--rm-bg); padding: 0 16px; margin-top: 16px;
  }
  .royal-maroon-template .wsec-eyebrow {
    font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: var(--rm-gold);
    margin: 0 0 18px; font-weight: 500;
  }

  /* HERO — formal invitation card with double border */
  .royal-maroon-template .wsec-hero {
    padding: 80px 0; min-height: 100vh; position: relative; overflow: hidden;
    display: grid; place-items: center;
  }
  .royal-maroon-template .wsec-hero-bg {
    position: absolute; inset: 0; background-size: cover; background-position: center;
    filter: brightness(0.55) saturate(0.85);
  }
  .royal-maroon-template .wsec-hero-veil {
    position: absolute; inset: 0; background: linear-gradient(180deg, rgba(74,0,20,0.3), rgba(74,0,20,0.7));
  }
  .royal-maroon-template .wsec-hero-inner {
    position: relative; z-index: 2; text-align: center; color: var(--rm-cream);
    padding: 64px 56px; max-width: 720px; background: rgba(74,0,20,0.5);
    backdrop-filter: blur(6px); border: 1px solid var(--rm-gold);
    position: relative;
  }
  .royal-maroon-template .wsec-hero-inner::before, .royal-maroon-template .wsec-hero-inner::after {
    content: ''; position: absolute; width: 28px; height: 28px; border: 2px solid var(--rm-gold);
  }
  .royal-maroon-template .wsec-hero-inner::before { top: 12px; left: 12px; border-right: 0; border-bottom: 0; }
  .royal-maroon-template .wsec-hero-inner::after { bottom: 12px; right: 12px; border-left: 0; border-top: 0; }
  .royal-maroon-template .wsec-names {
    font-family: 'Cinzel', serif; font-weight: 500; color: var(--rm-gold);
    font-size: clamp(2.4rem, 6vw, 4.5rem); line-height: 1.05; margin: 0 0 24px; letter-spacing: 0.08em;
    text-transform: uppercase;
  }
  .royal-maroon-template .wsec-names .wsec-name { display: block; }
  .royal-maroon-template .wsec-names .wsec-amp { font-size: 0.6em; color: var(--rm-cream); font-style: normal; display: block; margin: 0.2em 0; }
  .royal-maroon-template .wsec-date { font-family: 'Cinzel', serif; font-size: 0.95rem; margin: 0 0 8px; letter-spacing: 3px; text-transform: uppercase; color: var(--rm-cream); }
  .royal-maroon-template .wsec-venue { font-size: 0.95rem; margin: 0 0 32px; display: flex; align-items: center; justify-content: center; gap: 8px; color: var(--rm-cream); }
  .royal-maroon-template .wsec-venue .wsec-icon-inline { width: 16px; height: 16px; }
  .royal-maroon-template .wsec-countdown { display: flex; gap: 12px; justify-content: center; margin: 24px 0 0; flex-wrap: wrap; }
  .royal-maroon-template .wsec-cd-cell {
    background: rgba(0,0,0,0.25); border: 1px solid var(--rm-gold);
    padding: 14px 16px; min-width: 78px;
  }
  .royal-maroon-template .wsec-cd-num { display: block; font-family: 'Cinzel', serif; font-size: 2rem; font-weight: 500; line-height: 1; color: var(--rm-gold); }
  .royal-maroon-template .wsec-cd-lbl { display: block; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--rm-cream); margin-top: 6px; }
  .royal-maroon-template .wsec-cd-celebrated { font-family: 'Cinzel', serif; color: var(--rm-gold); }
  .royal-maroon-template .wsec-scroll-cue {
    margin-top: 32px; display: inline-flex; align-items: center; gap: 10px;
    color: var(--rm-gold); font-size: 10px; letter-spacing: 3px; text-transform: uppercase; text-decoration: none;
  }
  .royal-maroon-template .wsec-scroll-cue .wsec-icon-inline { width: 14px; height: 14px; }

  /* COUPLE */
  .royal-maroon-template .wsec-couple { background: var(--rm-bg); }
  .royal-maroon-template .wsec-couple-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; align-items: center;
    max-width: 920px; margin: 0 auto;
  }
  .royal-maroon-template .wsec-person { text-align: center; }
  .royal-maroon-template .wsec-person-photo-frame {
    width: clamp(170px, 22vw, 230px); height: clamp(170px, 22vw, 230px);
    margin: 0 auto 24px; position: relative; background: var(--rm-cream);
    border: 2px solid var(--rm-gold); padding: 6px;
  }
  .royal-maroon-template .wsec-person-photo { width: 100%; height: 100%; object-fit: cover; }
  .royal-maroon-template .wsec-person-name {
    font-family: 'Cinzel', serif; font-weight: 500; font-size: 1.6rem; margin: 0 0 8px;
    color: var(--rm-primary); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-person-parents { color: var(--rm-muted); font-size: 0.95rem; margin: 0; font-style: italic; }
  .royal-maroon-template .wsec-couple-amp {
    font-family: 'Cinzel', serif; font-size: 3rem; color: var(--rm-gold);
  }
  .royal-maroon-template .wsec-story {
    max-width: 760px; margin: 64px auto 0; text-align: center; padding: 48px 40px;
    background: var(--rm-cream); border: 1px solid var(--rm-gold); position: relative;
  }
  .royal-maroon-template .wsec-story::before, .royal-maroon-template .wsec-story::after {
    content: '◆'; position: absolute; color: var(--rm-gold); font-size: 14px;
  }
  .royal-maroon-template .wsec-story::before { top: 12px; left: 50%; transform: translateX(-50%); background: var(--rm-cream); padding: 0 12px; }
  .royal-maroon-template .wsec-story::after { bottom: 12px; left: 50%; transform: translateX(-50%); background: var(--rm-cream); padding: 0 12px; }
  .royal-maroon-template .wsec-icon-quote { width: 28px; height: 28px; color: var(--rm-gold); }
  .royal-maroon-template .wsec-story-text {
    margin: 12px 0; font-style: italic; font-size: 1.3rem;
    line-height: 1.6; color: var(--rm-fg); border: 0; padding: 0; background: transparent;
  }
  .royal-maroon-template .wsec-story-attrib { color: var(--rm-muted); font-size: 0.9rem; letter-spacing: 1px; }

  /* FAMILY */
  .royal-maroon-template .wsec-family { background: var(--rm-cream); }
  .royal-maroon-template .wsec-family-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; max-width: 920px; margin: 0 auto; align-items: start;
  }
  .royal-maroon-template .wsec-family-col { text-align: center; }
  .royal-maroon-template .wsec-family-name {
    font-family: 'Cinzel', serif; font-size: 1.2rem; margin: 0 0 24px; color: var(--rm-primary);
    letter-spacing: 0.1em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-family-photo-frame {
    width: 190px; height: 190px; margin: 0 auto 20px; overflow: hidden;
    background: var(--rm-bg); border: 2px solid var(--rm-gold); padding: 4px;
  }
  .royal-maroon-template .wsec-family-photo-frame img { width: 100%; height: 100%; object-fit: cover; }
  .royal-maroon-template .wsec-family-avatar {
    width: 190px; height: 190px; margin: 0 auto 20px;
    background: var(--rm-primary); color: var(--rm-gold); display: grid; place-items: center;
    font-family: 'Cinzel', serif; font-size: 4rem; font-weight: 500; border: 2px solid var(--rm-gold);
  }
  .royal-maroon-template .wsec-family-list { list-style: none; padding: 0; margin: 0; }
  .royal-maroon-template .wsec-family-list li { padding: 8px 0; }
  .royal-maroon-template .wsec-family-role {
    display: block; font-family: 'Cinzel', serif; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--rm-gold);
  }
  .royal-maroon-template .wsec-family-name-val { font-size: 1rem; color: var(--rm-fg); }
  .royal-maroon-template .wsec-family-divider {
    width: 1px; align-self: stretch; background: var(--rm-gold); position: relative;
  }
  .royal-maroon-template .wsec-family-divider::before {
    content: '◆'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    color: var(--rm-gold); background: var(--rm-cream); padding: 4px; font-size: 14px;
  }

  /* EVENTS */
  .royal-maroon-template .wsec-events { background: var(--rm-bg); }
  .royal-maroon-template .wsec-timeline {
    list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto;
  }
  .royal-maroon-template .wsec-timeline-item {
    display: grid; grid-template-columns: 60px 1fr; gap: 24px; align-items: start;
    padding: 24px 0; border-top: 1px solid var(--rm-line);
  }
  .royal-maroon-template .wsec-timeline-marker { font-family: 'Cinzel', serif; }
  .royal-maroon-template .wsec-timeline-num { color: var(--rm-gold); font-size: 1.2rem; }
  .royal-maroon-template .wsec-timeline-title {
    font-family: 'Cinzel', serif; font-weight: 500; font-size: 1.3rem; margin: 0 0 6px;
    color: var(--rm-primary); letter-spacing: 0.08em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-timeline-date {
    display: flex; align-items: center; gap: 8px; color: var(--rm-muted); font-size: 0.9rem; margin: 0 0 10px;
  }
  .royal-maroon-template .wsec-timeline-date .wsec-icon-inline { width: 16px; height: 16px; }
  .royal-maroon-template .wsec-timeline-desc { color: var(--rm-fg); margin: 0; }
  .royal-maroon-template .wsec-event-card {
    max-width: 560px; margin: 0 auto; padding: 48px 40px; background: var(--rm-cream);
    border: 2px solid var(--rm-gold); text-align: center; position: relative;
  }
  .royal-maroon-template .wsec-event-card::before, .royal-maroon-template .wsec-event-card::after {
    content: ''; position: absolute; width: 32px; height: 32px; border: 2px solid var(--rm-primary);
  }
  .royal-maroon-template .wsec-event-card::before { top: 8px; left: 8px; border-right: 0; border-bottom: 0; }
  .royal-maroon-template .wsec-event-card::after { bottom: 8px; right: 8px; border-left: 0; border-top: 0; }
  .royal-maroon-template .wsec-event-name {
    font-family: 'Cinzel', serif; font-weight: 500; font-size: 1.8rem; margin: 0 0 20px;
    color: var(--rm-primary); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-event-info {
    list-style: none; padding: 0; margin: 0 0 28px; display: grid; gap: 10px;
  }
  .royal-maroon-template .wsec-event-info li {
    display: flex; align-items: center; justify-content: center; gap: 10px; color: var(--rm-fg);
  }
  .royal-maroon-template .wsec-icon { width: 18px; height: 18px; color: var(--rm-gold); }

  /* GALLERY */
  .royal-maroon-template .wsec-gallery { background: var(--rm-cream); }
  .royal-maroon-template .wsec-gallery-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  .royal-maroon-template .wsec-gallery-item {
    padding: 0; border: 0; background: transparent; cursor: pointer; position: relative;
    overflow: hidden; aspect-ratio: 1; border: 1px solid var(--rm-gold); padding: 4px; background: var(--rm-bg);
  }
  .royal-maroon-template .wsec-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .royal-maroon-template .wsec-gallery-item:hover img { transform: scale(1.05); }
  .royal-maroon-template .wsec-gallery-caption {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 12px;
    background: linear-gradient(transparent, rgba(74,0,20,0.85)); color: var(--rm-cream); font-size: 0.85rem;
  }

  /* TRAVEL */
  .royal-maroon-template .wsec-travel { background: var(--rm-bg); }
  .royal-maroon-template .wsec-travel-layout {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; max-width: 1080px; margin: 0 auto;
  }
  .royal-maroon-template .wsec-travel-subtitle {
    font-family: 'Cinzel', serif; font-size: 1.2rem; margin: 0 0 20px; color: var(--rm-primary);
    letter-spacing: 0.1em; text-transform: uppercase; display: flex; align-items: center; gap: 10px;
  }
  .royal-maroon-template .wsec-travel-address { font-style: normal; color: var(--rm-fg); line-height: 1.8; display: grid; gap: 6px; }
  .royal-maroon-template .wsec-travel-address strong { font-family: 'Cinzel', serif; font-size: 1.1rem; }
  .royal-maroon-template .wsec-travel-notes { color: var(--rm-muted); font-size: 0.95rem; font-style: italic; }
  .royal-maroon-template .wsec-travel-map iframe { width: 100%; aspect-ratio: 4/3; border: 2px solid var(--rm-gold); }
  .royal-maroon-template .wsec-hotels { margin-top: 64px; }
  .royal-maroon-template .wsec-hotels-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .royal-maroon-template .wsec-hotel-card {
    display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center;
    padding: 20px; background: var(--rm-cream); border: 1px solid var(--rm-gold);
  }
  .royal-maroon-template .wsec-hotel-name { font-family: 'Cinzel', serif; font-size: 1.1rem; margin: 0 0 4px; color: var(--rm-primary); }
  .royal-maroon-template .wsec-hotel-address, .royal-maroon-template .wsec-hotel-distance { color: var(--rm-muted); font-size: 0.9rem; margin: 2px 0; display: flex; align-items: center; gap: 6px; }
  .royal-maroon-template .wsec-icon-sm { width: 12px; height: 12px; }

  /* GIFT */
  .royal-maroon-template .wsec-gift { background: var(--rm-cream); }
  .royal-maroon-template .wsec-gift-intro { text-align: center; max-width: 540px; margin: 0 auto 48px; color: var(--rm-muted); font-style: italic; }
  .royal-maroon-template .wsec-gift-list { list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto; display: grid; gap: 12px; }
  .royal-maroon-template .wsec-gift-item {
    display: grid; grid-template-columns: 56px 1fr; gap: 20px; align-items: start;
    padding: 24px; background: var(--rm-bg); border: 1px solid var(--rm-gold);
  }
  .royal-maroon-template .wsec-gift-icon { display: grid; place-items: center; }
  .royal-maroon-template .wsec-gift-icon .wsec-icon { width: 24px; height: 24px; color: var(--rm-gold); }
  .royal-maroon-template .wsec-gift-label { font-family: 'Cinzel', serif; font-size: 1.1rem; margin: 0 0 6px; color: var(--rm-primary); letter-spacing: 0.08em; text-transform: uppercase; }
  .royal-maroon-template .wsec-gift-value {
    display: inline-flex; align-items: center; gap: 8px; color: var(--rm-fg); text-decoration: none;
    font-size: 1rem; background: transparent; border: 0; padding: 0; cursor: pointer; word-break: break-all;
  }
  .royal-maroon-template .wsec-gift-value:hover { color: var(--rm-primary); }
  .royal-maroon-template .wsec-gift-value .wsec-icon { width: 16px; height: 16px; color: var(--rm-muted); }
  .royal-maroon-template .wsec-gift-note { color: var(--rm-muted); font-size: 0.9rem; margin: 8px 0 0; font-style: italic; }

  /* RSVP */
  .royal-maroon-template .wsec-rsvp { background: var(--rm-primary-dark); color: var(--rm-cream); text-align: center; }
  .royal-maroon-template .wsec-rsvp-title {
    font-family: 'Cinzel', serif; font-weight: 500; font-size: clamp(1.6rem, 3.5vw, 2.6rem);
    margin: 0 0 12px; color: var(--rm-gold); letter-spacing: 0.15em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-rsvp-sub { color: rgba(250,241,224,0.8); margin: 0 0 32px; }

  /* BUTTONS */
  .royal-maroon-template .wsec-btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
    font-family: 'Cinzel', serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    border-radius: 0; border: 1px solid; cursor: pointer; transition: all 0.3s; text-decoration: none; font-weight: 500;
  }
  .royal-maroon-template .wsec-btn .wsec-icon { width: 16px; height: 16px; }
  .royal-maroon-template .wsec-btn-primary { background: var(--rm-gold); color: var(--rm-primary-dark); border-color: var(--rm-gold); }
  .royal-maroon-template .wsec-btn-primary:hover { background: var(--rm-cream); color: var(--rm-primary); border-color: var(--rm-cream); }
  .royal-maroon-template .wsec-btn-outline { background: transparent; color: var(--rm-gold); border-color: var(--rm-gold); }
  .royal-maroon-template .wsec-btn-outline:hover { background: var(--rm-gold); color: var(--rm-primary-dark); }
  .royal-maroon-template .wsec-btn-ghost { background: transparent; color: var(--rm-fg); border-color: var(--rm-line); }
  .royal-maroon-template .wsec-btn-ghost:hover { border-color: var(--rm-primary); color: var(--rm-primary); }

  /* FOOTER */
  .royal-maroon-template .wsec-footer { background: var(--rm-primary-dark); color: var(--rm-cream); padding: 80px 0; text-align: center; }
  .royal-maroon-template .wsec-footer-eyebrow { font-family: 'Cinzel', serif; font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--rm-gold); margin: 0 0 24px; }
  .royal-maroon-template .wsec-footer-names {
    font-family: 'Cinzel', serif; font-weight: 500; font-size: clamp(1.8rem, 4.5vw, 3rem);
    margin: 0 0 16px; line-height: 1.1; color: var(--rm-gold); letter-spacing: 0.1em; text-transform: uppercase;
  }
  .royal-maroon-template .wsec-footer-amp { color: var(--rm-cream); display: block; margin: 0.2em 0; font-size: 0.5em; }
  .royal-maroon-template .wsec-footer-date { color: var(--rm-cream); font-size: 0.9rem; margin: 0 0 32px; }
  .royal-maroon-template .wsec-footer-made { color: rgba(250,241,224,0.5); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

  /* FLOATING UI */
  .royal-maroon-template .wsec-share-rail a { background: var(--rm-cream); color: var(--rm-primary); border: 1px solid var(--rm-gold); }
  .royal-maroon-template .wsec-share-rail a:hover { background: var(--rm-gold); color: var(--rm-primary-dark); }
  .royal-maroon-template .wsec-music-toggle { background: var(--rm-primary); color: var(--rm-gold); border: 1px solid var(--rm-gold); border-radius: 0; }
  .royal-maroon-template .wsec-music-toggle .wsec-icon { width: 22px; height: 22px; }

  /* RESPONSIVE */
  @media (max-width: 900px) {
    .royal-maroon-template .wsec-hero-inner { padding: 48px 28px; }
    .royal-maroon-template .wsec-couple-grid { grid-template-columns: 1fr; gap: 32px; }
    .royal-maroon-template .wsec-couple-amp { font-size: 2.5rem; }
    .royal-maroon-template .wsec-family-grid { grid-template-columns: 1fr; gap: 48px; }
    .royal-maroon-template .wsec-family-divider { display: none; }
    .royal-maroon-template .wsec-gallery-grid { grid-template-columns: repeat(2, 1fr); }
    .royal-maroon-template .wsec-travel-layout { grid-template-columns: 1fr; }
  }
  @media (max-width: 480px) {
    .royal-maroon-template .wsec-gallery-grid { grid-template-columns: 1fr; }
    .royal-maroon-template .wsec-event-card { padding: 40px 24px; }
  }
</style>

<div class="royal-maroon-template">
  <%- include('../partials/sections/_hero', { wedding, scope: 'rm' }) %>

  <main>
    <%- include('../partials/sections/_couple', { wedding }) %>
    <%- include('../partials/sections/_family', { wedding }) %>
    <%- include('../partials/sections/_events', { wedding }) %>
    <%- include('../partials/sections/_gallery', { wedding }) %>
    <%- include('../partials/sections/_travel', { wedding }) %>
    <%- include('../partials/sections/_gift', { wedding }) %>
    <%- include('../partials/sections/_rsvp-cta', { wedding }) %>
  </main>

  <%- include('../partials/sections/_footer', { wedding }) %>
  <%- include('../partials/sections/_share-music', { wedding }) %>
</div>
