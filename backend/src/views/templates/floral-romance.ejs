<!--
  Floral Romance — botanical, soft blush/sage, hand-drawn feel
  Fonts: Dancing Script (display) + Inter (body)
-->
<%- include('../partials/sections/icons') %>
<style>
  .floral-romance-template {
    --fr-bg: #FFF5F0;
    --fr-fg: #4A3B36;
    --fr-muted: #8C7B73;
    --fr-line: #F0DDD0;
    --fr-primary: #D08A8A;
    --fr-secondary: #A8B89A;
    --fr-blush: #F5D5C8;
    --fr-ink: #5C4A45;
    font-family: 'Inter', system-ui, -apple-system, sans-serif;
    color: var(--fr-fg); background: var(--fr-bg);
    line-height: 1.7; font-size: 17px;
  }
  .floral-romance-template .wsec-container { max-width: 1080px; margin: 0 auto; padding: 0 28px; position: relative; }
  .floral-romance-template .wsec { padding: clamp(72px, 10vw, 130px) 0; position: relative; }
  .floral-romance-template .wsec-eyebrow-heading {
    font-family: 'Dancing Script', cursive; font-weight: 400;
    font-size: clamp(2.6rem, 5.5vw, 4.5rem); text-align: center; color: var(--fr-primary);
    margin: 0 0 16px; line-height: 1.1;
  }
  .floral-romance-template .wsec-eyebrow-heading::after {
    content: '🌿'; display: block; text-align: center; color: var(--fr-secondary);
    font-size: 1.4rem; margin-top: 16px; opacity: 0.7;
  }
  .floral-romance-template .wsec-eyebrow {
    font-size: 11px; letter-spacing: 4px; text-transform: uppercase; color: var(--fr-muted);
    margin: 0 0 18px; font-weight: 500;
  }

  /* HERO — soft photo with sage overlay */
  .floral-romance-template .wsec-hero {
    padding: 0; min-height: 100vh; position: relative; overflow: hidden;
    display: grid; place-items: center;
  }
  .floral-romance-template .wsec-hero-bg {
    position: absolute; inset: 0; background-size: cover; background-position: center;
    filter: brightness(0.95) saturate(0.9);
  }
  .floral-romance-template .wsec-hero-veil {
    position: absolute; inset: 0;
    background: linear-gradient(180deg, rgba(255,245,240,0.4), rgba(168,184,154,0.55));
  }
  .floral-romance-template .wsec-hero-inner {
    position: relative; z-index: 2; text-align: center; color: var(--fr-ink);
    padding: 64px 40px; max-width: 720px;
  }
  .floral-romance-template .wsec-names {
    font-family: 'Dancing Script', cursive; font-weight: 400; color: var(--fr-ink);
    font-size: clamp(3rem, 8vw, 6rem); line-height: 1; margin: 0 0 16px;
  }
  .floral-romance-template .wsec-names .wsec-name { display: block; }
  .floral-romance-template .wsec-names .wsec-amp { color: var(--fr-primary); font-size: 0.8em; display: block; margin: 0.2em 0; }
  .floral-romance-template .wsec-date { font-size: 1rem; margin: 0 0 8px; letter-spacing: 2px; text-transform: uppercase; color: var(--fr-muted); }
  .floral-romance-template .wsec-venue { font-size: 0.95rem; margin: 0 0 32px; display: flex; align-items: center; justify-content: center; gap: 8px; }
  .floral-romance-template .wsec-venue .wsec-icon-inline { width: 16px; height: 16px; }
  .floral-romance-template .wsec-countdown { display: flex; gap: 12px; justify-content: center; margin: 24px 0 0; flex-wrap: wrap; }
  .floral-romance-template .wsec-cd-cell {
    background: rgba(255,255,255,0.6); backdrop-filter: blur(8px);
    border: 1px solid rgba(208,138,138,0.25); padding: 14px 16px; min-width: 76px; border-radius: 8px;
  }
  .floral-romance-template .wsec-cd-num { display: block; font-family: 'Dancing Script', cursive; font-size: 2.4rem; font-weight: 400; line-height: 1; color: var(--fr-primary); }
  .floral-romance-template .wsec-cd-lbl { display: block; font-size: 9px; letter-spacing: 2px; text-transform: uppercase; color: var(--fr-muted); margin-top: 4px; }
  .floral-romance-template .wsec-cd-celebrated { font-family: 'Dancing Script', cursive; color: var(--fr-primary); }
  .floral-romance-template .wsec-scroll-cue {
    margin-top: 32px; display: inline-flex; align-items: center; gap: 10px;
    color: var(--fr-muted); font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    text-decoration: none;
  }
  .floral-romance-template .wsec-scroll-cue .wsec-icon-inline { width: 14px; height: 14px; }

  /* COUPLE */
  .floral-romance-template .wsec-couple { background: var(--fr-bg); }
  .floral-romance-template .wsec-couple-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 40px; align-items: center;
    max-width: 880px; margin: 0 auto;
  }
  .floral-romance-template .wsec-person { text-align: center; }
  .floral-romance-template .wsec-person-photo-frame {
    width: clamp(170px, 20vw, 220px); height: clamp(170px, 20vw, 220px);
    border-radius: 50%; overflow: hidden; margin: 0 auto 20px; position: relative;
    background: var(--fr-blush); padding: 10px;
  }
  .floral-romance-template .wsec-person-photo { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .floral-romance-template .wsec-person-name {
    font-family: 'Dancing Script', cursive; font-weight: 400; font-size: 2.2rem;
    color: var(--fr-primary); margin: 0 0 6px;
  }
  .floral-romance-template .wsec-person-parents { color: var(--fr-muted); font-size: 0.9rem; margin: 0; }
  .floral-romance-template .wsec-couple-amp { font-family: 'Dancing Script', cursive; font-size: 3.5rem; color: var(--fr-primary); }
  .floral-romance-template .wsec-story {
    max-width: 720px; margin: 64px auto 0; text-align: center; padding: 0;
  }
  .floral-romance-template .wsec-icon-quote { width: 28px; height: 28px; color: var(--fr-primary); }
  .floral-romance-template .wsec-story-text {
    margin: 12px 0; font-family: 'Dancing Script', cursive; font-size: 1.6rem;
    line-height: 1.4; color: var(--fr-ink); border: 0; padding: 0; background: transparent;
  }
  .floral-romance-template .wsec-story-attrib { color: var(--fr-muted); font-size: 0.85rem; letter-spacing: 1px; }

  /* OUR STORY */
  .floral-romance-template .wsec-our-story { background: #fff; }
  .floral-romance-template .wsec-our-story-body { max-width: 680px; margin: 0 auto; text-align: center; }
  .floral-romance-template .wsec-our-story-body p {
    font-family: 'Dancing Script', cursive; font-size: clamp(1.2rem, 2.8vw, 1.55rem);
    color: var(--fr-ink); line-height: 1.6; margin: 0 0 16px;
  }
  .floral-romance-template .wsec-our-story-body p:last-child { margin-bottom: 0; }
  .floral-romance-template .wsec-our-story-divider { margin: 28px auto 18px; }
  .floral-romance-template .wsec-our-story-divider::before,
  .floral-romance-template .wsec-our-story-divider::after { background: var(--fr-line); }
  .floral-romance-template .wsec-our-story-divider .wsec-divider-mark { color: var(--fr-primary); }
  .floral-romance-template .wsec-our-story-attrib {
    text-align: center; font-family: 'Dancing Script', cursive; font-size: 1.1rem;
    color: var(--fr-muted); font-style: italic;
  }

  /* FAMILY */
  .floral-romance-template .wsec-family { background: #fff; }
  .floral-romance-template .wsec-family-grid {
    display: grid; grid-template-columns: 1fr auto 1fr; gap: 48px; max-width: 920px; margin: 0 auto; align-items: start;
  }
  .floral-romance-template .wsec-family-col { text-align: center; }
  .floral-romance-template .wsec-family-name {
    font-family: 'Dancing Script', cursive; font-size: 1.8rem; margin: 0 0 24px; color: var(--fr-primary);
  }
  .floral-romance-template .wsec-family-photo-frame {
    width: clamp(120px, 22vw, 180px); height: clamp(120px, 22vw, 180px);
    border-radius: 50%; margin: 0 auto 20px; overflow: hidden;
    background: var(--fr-blush); padding: 8px;
  }
  .floral-romance-template .wsec-family-photo-frame img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
  .floral-romance-template .wsec-family-avatar {
    width: clamp(120px, 22vw, 180px); height: clamp(120px, 22vw, 180px);
    border-radius: 50%; margin: 0 auto 20px;
    background: var(--fr-blush); color: var(--fr-primary); display: grid; place-items: center;
    font-family: 'Dancing Script', cursive; font-size: clamp(2.6rem, 5vw, 4rem);
  }
  .floral-romance-template .wsec-family-list { list-style: none; padding: 0; margin: 0; }
  .floral-romance-template .wsec-family-list li { padding: 6px 0; }
  .floral-romance-template .wsec-family-role {
    display: block; font-size: 10px; letter-spacing: 2px; text-transform: uppercase; color: var(--fr-muted);
  }
  .floral-romance-template .wsec-family-name-val { font-size: 1rem; color: var(--fr-fg); }
  .floral-romance-template .wsec-family-divider {
    width: 1px; align-self: stretch; background: var(--fr-line); position: relative;
  }
  .floral-romance-template .wsec-family-divider::before {
    content: '🌸'; position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
    color: var(--fr-primary); background: #fff; padding: 8px; border-radius: 50%; font-size: 18px;
  }

  /* EVENTS */
  .floral-romance-template .wsec-events { background: var(--fr-bg); }
  .floral-romance-template .wsec-timeline {
    list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto;
  }
  .floral-romance-template .wsec-timeline-item {
    display: grid; grid-template-columns: 1fr; gap: 4px; align-items: start;
    padding: 24px 0; border-top: 1px solid var(--fr-line);
  }
  .floral-romance-template .wsec-timeline-marker { display: none; }
  .floral-romance-template .wsec-timeline-title {
    font-family: 'Dancing Script', cursive; font-size: 1.8rem; margin: 0 0 6px; color: var(--fr-primary);
  }
  .floral-romance-template .wsec-timeline-date {
    display: flex; align-items: center; gap: 8px; color: var(--fr-muted); font-size: 0.9rem; margin: 0 0 8px;
  }
  .floral-romance-template .wsec-timeline-date .wsec-icon-inline { width: 16px; height: 16px; }
  .floral-romance-template .wsec-timeline-desc { color: var(--fr-fg); margin: 0; }
  .floral-romance-template .wsec-event-card {
    max-width: 520px; margin: 0 auto; padding: 48px 36px; background: #fff;
    text-align: center; border: 1px solid var(--fr-line); border-radius: 8px;
  }
  .floral-romance-template .wsec-event-name {
    font-family: 'Dancing Script', cursive; font-size: 2.6rem; margin: 0 0 20px; color: var(--fr-primary);
  }
  .floral-romance-template .wsec-event-info {
    list-style: none; padding: 0; margin: 0 0 28px; display: grid; gap: 8px;
  }
  .floral-romance-template .wsec-event-info li {
    display: flex; align-items: center; justify-content: center; gap: 10px; color: var(--fr-fg);
  }
  .floral-romance-template .wsec-icon { width: 18px; height: 18px; color: var(--fr-primary); }

  /* GALLERY */
  .floral-romance-template .wsec-gallery { background: #fff; }
  .floral-romance-template .wsec-gallery-grid {
    display: grid; grid-template-columns: repeat(3, 1fr); gap: 12px;
  }
  .floral-romance-template .wsec-gallery-item {
    padding: 0; border: 0; background: transparent; cursor: pointer; position: relative;
    overflow: hidden; aspect-ratio: 1; border-radius: 8px;
  }
  .floral-romance-template .wsec-gallery-item img { width: 100%; height: 100%; object-fit: cover; transition: transform 0.6s; }
  .floral-romance-template .wsec-gallery-item:hover img { transform: scale(1.05); }
  .floral-romance-template .wsec-gallery-caption {
    position: absolute; bottom: 0; left: 0; right: 0; padding: 12px;
    background: linear-gradient(transparent, rgba(0,0,0,0.6)); color: white; font-size: 0.85rem;
  }

  /* TRAVEL */
  .floral-romance-template .wsec-travel { background: var(--fr-bg); }
  .floral-romance-template .wsec-travel-layout {
    display: grid; grid-template-columns: 1fr 1.4fr; gap: 48px; max-width: 1080px; margin: 0 auto;
  }
  .floral-romance-template .wsec-travel-subtitle {
    font-family: 'Dancing Script', cursive; font-size: 1.8rem; margin: 0 0 20px; color: var(--fr-primary);
    display: flex; align-items: center; gap: 10px;
  }
  .floral-romance-template .wsec-travel-address { font-style: normal; color: var(--fr-fg); line-height: 1.8; display: grid; gap: 6px; }
  .floral-romance-template .wsec-travel-address strong { font-size: 1.1rem; }
  .floral-romance-template .wsec-travel-notes { color: var(--fr-muted); font-size: 0.95rem; }
  .floral-romance-template .wsec-travel-map iframe { width: 100%; aspect-ratio: 4/3; border: 0; background: var(--fr-line); border-radius: 8px; }
  .floral-romance-template .wsec-hotels { margin-top: 64px; }
  .floral-romance-template .wsec-hotels-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 12px; }
  .floral-romance-template .wsec-hotel-card {
    display: grid; grid-template-columns: 1fr auto; gap: 16px; align-items: center;
    padding: 20px; background: #fff; border: 1px solid var(--fr-line); border-radius: 8px;
  }
  .floral-romance-template .wsec-hotel-name { font-size: 1.1rem; margin: 0 0 4px; }
  .floral-romance-template .wsec-hotel-address, .floral-romance-template .wsec-hotel-distance { color: var(--fr-muted); font-size: 0.9rem; margin: 2px 0; display: flex; align-items: center; gap: 6px; }
  .floral-romance-template .wsec-icon-sm { width: 12px; height: 12px; }

  /* GIFT */
  .floral-romance-template .wsec-gift { background: #fff; }
  .floral-romance-template .wsec-gift-intro { text-align: center; max-width: 540px; margin: 0 auto 48px; color: var(--fr-muted); }
  .floral-romance-template .wsec-gift-list { list-style: none; padding: 0; margin: 0; max-width: 720px; margin-left: auto; margin-right: auto; display: grid; gap: 12px; }
  .floral-romance-template .wsec-gift-item {
    display: grid; grid-template-columns: 56px 1fr; gap: 20px; align-items: start;
    padding: 24px; background: var(--fr-bg); border: 1px solid var(--fr-line); border-radius: 8px;
  }
  .floral-romance-template .wsec-gift-icon { display: grid; place-items: center; }
  .floral-romance-template .wsec-gift-icon .wsec-icon { width: 24px; height: 24px; color: var(--fr-primary); }
  .floral-romance-template .wsec-gift-label { font-family: 'Dancing Script', cursive; font-size: 1.5rem; margin: 0 0 6px; color: var(--fr-primary); }
  .floral-romance-template .wsec-gift-value {
    display: inline-flex; align-items: center; gap: 8px; color: var(--fr-fg); text-decoration: none;
    font-size: 1rem; background: transparent; border: 0; padding: 0; cursor: pointer; word-break: break-all;
  }
  .floral-romance-template .wsec-gift-value:hover { color: var(--fr-primary); }
  .floral-romance-template .wsec-gift-value .wsec-icon { width: 16px; height: 16px; color: var(--fr-muted); }
  .floral-romance-template .wsec-gift-note { color: var(--fr-muted); font-size: 0.9rem; margin: 8px 0 0; }

  /* WISHES */
  .floral-romance-template .wsec-wishes { background: var(--fr-secondary); color: var(--fr-bg); }
  .floral-romance-template .wsec-wishes-sub { text-align: center; color: rgba(255,255,255,0.9); max-width: 540px; margin: 0 auto 32px; }
  .floral-romance-template .wsec-wishes-form {
    max-width: 560px; margin: 0 auto 56px; display: grid; gap: 14px;
  }
  .floral-romance-template .wsec-wishes-field { display: block; }
  .floral-romance-template .wsec-wishes-label {
    display: block; font-size: 10px; letter-spacing: 3px; text-transform: uppercase;
    color: rgba(255,255,255,0.85); margin-bottom: 8px; font-weight: 500;
  }
  .floral-romance-template .wsec-wishes-form input,
  .floral-romance-template .wsec-wishes-form textarea {
    width: 100%; padding: 14px 16px; border: 1px solid rgba(255,255,255,0.35);
    border-radius: 8px; background: rgba(255,255,255,0.92); color: var(--fr-ink);
    font-family: inherit; font-size: 15px;
  }
  .floral-romance-template .wsec-wishes-form input:focus,
  .floral-romance-template .wsec-wishes-form textarea:focus {
    outline: none; border-color: var(--fr-bg); box-shadow: 0 0 0 3px rgba(255,255,255,0.3);
  }
  .floral-romance-template .wsec-wishes-form textarea { resize: vertical; min-height: 90px; }
  .floral-romance-template .wsec-wishes-counter { text-align: right; font-size: 11px; color: rgba(255,255,255,0.7); margin: -8px 4px 0; }
  .floral-romance-template .wsec-wishes-submit { background: var(--fr-bg); color: var(--fr-primary); border-color: var(--fr-bg); width: 100%; justify-content: center; }
  .floral-romance-template .wsec-wishes-submit:hover { background: var(--fr-primary); color: var(--fr-bg); border-color: var(--fr-primary); }
  .floral-romance-template .wsec-wishes-status { text-align: center; font-size: 13px; margin: 8px 0 0; min-height: 1em; }
  .floral-romance-template .wsec-wishes-status.is-success { color: var(--fr-bg); font-weight: 600; }
  .floral-romance-template .wsec-wishes-status.is-error { color: #FFE5E5; }
  .floral-romance-template .wsec-wishes-list-wrap { max-width: 720px; margin: 0 auto; }
  .floral-romance-template .wsec-wishes-list-heading {
    font-family: 'Dancing Script', cursive; font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    color: var(--fr-bg); text-align: center; margin: 0 0 24px;
  }
  .floral-romance-template .wsec-wishes-list { list-style: none; padding: 0; margin: 0; display: grid; gap: 14px; }
  .floral-romance-template .wsec-wishes-item {
    background: rgba(255,255,255,0.92); border-radius: 8px; padding: 18px 20px;
    color: var(--fr-ink);
  }
  .floral-romance-template .wsec-wishes-msg { font-family: 'Dancing Script', cursive; font-size: 1.2rem; line-height: 1.4; margin-bottom: 8px; }
  .floral-romance-template .wsec-wishes-meta { display: flex; gap: 10px; align-items: center; font-size: 12px; color: var(--fr-muted); }
  .floral-romance-template .wsec-wishes-name { font-weight: 600; }
  .floral-romance-template .wsec-wishes-empty { text-align: center; color: rgba(255,255,255,0.85); padding: 16px 0; }

  /* BUTTONS */
  .floral-romance-template .wsec-btn {
    display: inline-flex; align-items: center; gap: 8px; padding: 14px 28px;
    font-family: 'Inter', sans-serif; font-size: 11px; letter-spacing: 3px; text-transform: uppercase;
    border-radius: 100px; border: 1px solid; cursor: pointer; transition: all 0.3s; text-decoration: none;
    font-weight: 500;
  }
  .floral-romance-template .wsec-btn .wsec-icon { width: 16px; height: 16px; }
  .floral-romance-template .wsec-btn-primary { background: var(--fr-bg); color: var(--fr-primary); border-color: var(--fr-bg); }
  .floral-romance-template .wsec-btn-primary:hover { background: var(--fr-primary); color: var(--fr-bg); border-color: var(--fr-primary); }
  .floral-romance-template .wsec-btn-outline { background: transparent; color: var(--fr-primary); border-color: var(--fr-primary); }
  .floral-romance-template .wsec-btn-outline:hover { background: var(--fr-primary); color: var(--fr-bg); }
  .floral-romance-template .wsec-btn-ghost { background: transparent; color: var(--fr-fg); border-color: var(--fr-line); }
  .floral-romance-template .wsec-btn-ghost:hover { border-color: var(--fr-primary); color: var(--fr-primary); }

  /* FOOTER */
  .floral-romance-template .wsec-footer { background: var(--fr-blush); padding: 80px 0; text-align: center; }
  .floral-romance-template .wsec-footer-eyebrow { font-size: 10px; letter-spacing: 4px; text-transform: uppercase; color: var(--fr-muted); margin: 0 0 24px; }
  .floral-romance-template .wsec-footer-names {
    font-family: 'Dancing Script', cursive; font-size: clamp(2.6rem, 6vw, 4.5rem);
    margin: 0 0 16px; line-height: 1; color: var(--fr-primary);
  }
  .floral-romance-template .wsec-footer-amp { color: var(--fr-secondary); display: block; margin: 0.2em 0; font-size: 0.7em; }
  .floral-romance-template .wsec-footer-date { color: var(--fr-muted); font-size: 0.9rem; margin: 0 0 32px; }
  .floral-romance-template .wsec-footer-made { color: var(--fr-muted); font-size: 0.75rem; letter-spacing: 2px; text-transform: uppercase; }

  /* FLOATING UI */
  .floral-romance-template .wsec-share-rail a { background: var(--fr-bg); color: var(--fr-primary); border: 1px solid var(--fr-line); }
  .floral-romance-template .wsec-share-rail a:hover { background: var(--fr-primary); color: var(--fr-bg); border-color: var(--fr-primary); }
  .floral-romance-template .wsec-music-toggle { background: var(--fr-primary); color: var(--fr-bg); border: 0; border-radius: 50%; }
  .floral-romance-template .wsec-music-toggle .wsec-icon { width: 22px; height: 22px; }

  /* RESPONSIVE */
  /* Tablet (≤768px): tighten hero names and hero inner padding for
     iPad portrait — falls between the 900px and 640px breakpoints. */
  @media (max-width: 768px) {
    .floral-romance-template .wsec-names { font-size: clamp(2.6rem, 8vw, 4.2rem); }
    .floral-romance-template .wsec-hero-inner { padding: 56px 28px; }
    .floral-romance-template .wsec-eyebrow-heading { font-size: clamp(1.6rem, 4vw, 2.4rem); }
  }
  /* Tablet (≤900px): single-column couple + family, 2-col gallery. */
  @media (max-width: 900px) {
    .floral-romance-template .wsec { padding: clamp(56px, 12vw, 88px) 0; }
    .floral-romance-template .wsec-hero-inner { padding: 48px 24px; }
    .floral-romance-template .wsec-couple-grid { grid-template-columns: 1fr; gap: 32px; }
    .floral-romance-template .wsec-couple-amp { font-size: 2.5rem; }
