<!DOCTYPE html>
<html lang="<%= wedding.language || 'en' %>">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title><%= title %></title>
    <meta name="description" content="<%= description %>">
    
    <!-- Open Graph / Social SEO -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= baseUrl %>/<%= wedding.slug %>">
    <meta property="og:title" content="<%= title %>">
    <meta property="og:description" content="<%= description %>">
    <meta property="og:image" content="<%= ogImage %>">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <% if (wedding.language === 'ml' || wedding.language === 'en_ml') { %>
        <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+Malayalam:wght@400;600;700&display=swap" rel="stylesheet">
    <% } %>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;0,700;1,400&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">

    <!-- Core CSS -->
    <link rel="stylesheet" href="/css/style.css">
    
    <style>
        :root {
            --primary-color: <%= wedding.theme?.primaryColor || '#D4A574' %>;
            --font-heading: '<%= wedding.theme?.fontFamily || 'Playfair Display' %>', serif;
            <% if (wedding.language === 'ml' || wedding.language === 'en_ml') { %>
                --font-body: 'Noto Sans Malayalam', 'Inter', sans-serif;
            <% } else { %>
                --font-body: 'Inter', sans-serif;
            <% } %>
        }
    </style>
</head>
<body
    class="template-<%= wedding.templateId %> theme-<%= wedding.theme?.mode || 'light' %>"
    data-wedding-date="<%= wedding.weddingDate ? new Date(wedding.weddingDate).toISOString() : '' %>"
    data-music-url="<%= wedding.musicUrl || '' %>">

    <%- include(`../templates/${wedding.templateId}`, { wedding }) %>

    <!-- Free badge for free-tier users (Pro users hide this) -->
    <% if (!wedding.userId || !wedding.userId.plan || wedding.userId.plan === 'free') { %>
        <div style="text-align: center; padding: 20px; background: #f5f5f5; font-size: 13px;">
            <%- include('../partials/free-badge') %>
        </div>
    <% } %>

    <!-- RSVP Modal Template -->
    <% if (wedding.isRsvpEnabled) { %>
        <%- include('../partials/rsvp-modal', { wedding }) %>
    <% } %>

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/gsap.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/gsap@3.12.2/dist/ScrollTrigger.min.js"></script>
    <script src="/js/main.js"></script>
</body>
</html>
