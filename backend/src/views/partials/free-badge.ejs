<!--
  Free badge — rendered for free-tier users at the bottom of every template.
  Shown to nudge upgrades but kept small and non-intrusive.
  The container templates control the surrounding spacing/background.
-->
<a href="/" class="free-badge-link" style="
  display: inline-block;
  padding: 8px 16px;
  background: rgba(255, 255, 255, 0.15);
  border: 1px solid currentColor;
  border-radius: 20px;
  color: inherit;
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.5px;
  opacity: 0.85;
  transition: opacity 0.2s ease, transform 0.2s ease;
" onmouseover="this.style.opacity='1'; this.style.transform='translateY(-1px)';" onmouseout="this.style.opacity='0.85'; this.style.transform='translateY(0)';">
  Made with 💕 Wedding Cards
</a>
